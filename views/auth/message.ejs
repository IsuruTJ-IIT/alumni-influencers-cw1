<%- include('../partials/head', { title: title }) %>
<%- include('../partials/nav') %>

<div class="flex justify-center items-center py-12">
  <div class="card w-full max-w-md p-8 text-center">
    <div class="mb-6 flex justify-center">
      <div class="bg-primary/10 p-4 rounded-full">
        <svg class="w-12 h-12 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      </div>
    </div>
    
    <h1 class="text-2xl font-bold text-slate-900 mb-4"><%= title %></h1>
    <p class="text-slate-600 mb-8"><%= message %></p>

    <div class="space-y-3">
      <a href="/login" class="btn-primary w-full py-2.5">Go to Login</a>
      <a href="/" class="btn-secondary w-full py-2.5">Back to Home</a>
      <a href="/outbox" class="block mt-4 text-sm font-medium text-primary hover:text-primary-hover">Open Local Outbox</a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
