<%- include('../partials/head', { title: 'Dashboard' }) %>
<%- include('../partials/nav') %>

<div class="py-6">
  <div class="mb-8">
    <h1 class="page-title">Dashboard</h1>
    <p class="text-slate-600">Overview of your account and quick links to your areas of access.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <!-- User Profile Summary Card -->
    <div class="card p-6 col-span-1">
      <div class="flex items-center space-x-4 mb-4">
        <% if (typeof profile !== 'undefined' && profile && profile.profile_image_data) { %>
          <img src="<%= profile.profile_image_data %>" alt="Profile Image" class="w-14 h-14 rounded-full object-cover border border-slate-200">
        <% } else { %>
          <div class="bg-primary/10 p-3 rounded-full flex-shrink-0">
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
          </div>
        <% } %>
        <div>
          <h2 class="text-xl font-bold text-slate-900"><%= currentUser.fullName %></h2>
          <p class="text-sm text-slate-500"><span class="capitalize bg-slate-100 text-slate-800 px-2 py-0.5 rounded text-xs font-medium"><%= currentUser.role %></span></p>
        </div>
      </div>
      
      <div class="border-t border-slate-100 pt-4 mt-2">
        <p class="text-sm text-slate-600 flex justify-between mb-2">
          <span class="font-medium text-slate-900">Email</span> 
          <span><%= currentUser.email %></span>
        </p>
      </div>

      <div class="mt-6">
        <form action="/logout" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn-secondary w-full text-red-600 hover:bg-red-50 hover:text-red-700 hover:border-red-200">Logout</button>
        </form>
      </div>
    </div>

    <!-- Quick Links Area -->
    <div class="col-span-1 md:col-span-2 space-y-6">
      
      <% if (currentUser.role === 'alumnus') { %>
        <div class="card p-6">
          <h2 class="text-lg font-bold text-slate-900 mb-4 border-b border-slate-100 pb-2">Alumnus Actions</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a href="/profile" class="block p-4 rounded-lg border border-slate-200 hover:border-primary hover:shadow-sm transition-all group">
              <h3 class="font-semibold text-slate-900 group-hover:text-primary mb-1">My Profile</h3>
              <p class="text-xs text-slate-500">Manage your details, availability, and expected rate.</p>
            </a>
            <a href="/bidding" class="block p-4 rounded-lg border border-slate-200 hover:border-primary hover:shadow-sm transition-all group">
              <h3 class="font-semibold text-slate-900 group-hover:text-primary mb-1">Bidding Dashboard</h3>
              <p class="text-xs text-slate-500">View and accept bids from universities.</p>
            </a>
          </div>
        </div>
      <% } %>

      <% if (currentUser.role === 'university') { %>
        <div class="card p-6">
          <h2 class="text-lg font-bold text-slate-900 mb-4 border-b border-slate-100 pb-2">University Analytics Area</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a href="/university/dashboard" class="block p-4 rounded-lg border border-slate-200 hover:border-primary hover:shadow-sm transition-all group">
              <h3 class="font-semibold text-slate-900 group-hover:text-primary mb-1">Analytics Dashboard</h3>
              <p class="text-xs text-slate-500">View high-level campaign metrics and ROI.</p>
            </a>
            <a href="/university/alumni" class="block p-4 rounded-lg border border-slate-200 hover:border-primary hover:shadow-sm transition-all group">
              <h3 class="font-semibold text-slate-900 group-hover:text-primary mb-1">Alumni Database</h3>
              <p class="text-xs text-slate-500">Search and bid on alumni influencers.</p>
            </a>
          </div>
        </div>
      <% } %>

      <% if (currentUser.role === 'developer') { %>
        <div class="card p-6">
          <h2 class="text-lg font-bold text-slate-900 mb-4 border-b border-slate-100 pb-2">Developer Tools</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a href="/developer/tokens" class="block p-4 rounded-lg border border-slate-200 hover:border-primary hover:shadow-sm transition-all group">
              <h3 class="font-semibold text-slate-900 group-hover:text-primary mb-1">API Tokens</h3>
              <p class="text-xs text-slate-500">Manage your API authentication tokens.</p>
            </a>
            <a href="/winner-selection" class="block p-4 rounded-lg border border-slate-200 hover:border-primary hover:shadow-sm transition-all group">
              <h3 class="font-semibold text-slate-900 group-hover:text-primary mb-1">Winner Selection</h3>
              <p class="text-xs text-slate-500">Manually trigger the winner selection algorithm.</p>
            </a>
            <a href="/api-docs" class="block p-4 rounded-lg border border-slate-200 hover:border-primary hover:shadow-sm transition-all group">
              <h3 class="font-semibold text-slate-900 group-hover:text-primary mb-1">API Documentation</h3>
              <p class="text-xs text-slate-500">Swagger / OpenAPI documentation.</p>
            </a>
            <a href="/outbox" class="block p-4 rounded-lg border border-slate-200 hover:border-primary hover:shadow-sm transition-all group">
              <h3 class="font-semibold text-slate-900 group-hover:text-primary mb-1">Local Outbox</h3>
              <p class="text-xs text-slate-500">View system generated emails and notifications.</p>
            </a>
          </div>
        </div>
      <% } %>
      
    </div>
  </div>
</div>

<%- include('../partials/footer') %>