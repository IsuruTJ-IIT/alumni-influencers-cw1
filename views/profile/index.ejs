<%- include('../partials/head', { title: 'My Profile' }) %>
<%- include('../partials/nav') %>

<div class="py-6">
  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="page-title mb-1">My Profile</h1>
      <p class="text-slate-600">Manage your professional information, degrees, and employment history.</p>
    </div>
  </div>

  <% if (success) { %>
    <div class="bg-green-50 border-l-4 border-green-500 p-4 mb-6" role="alert">
      <p class="text-sm text-green-700"><%= success %></p>
    </div>
  <% } %>

  <% if (error) { %>
    <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6" role="alert">
      <p class="text-sm text-red-700"><%= error %></p>
    </div>
  <% } %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    
    <!-- Left Column: Profile Completion & Image -->
    <div class="space-y-6">
      <!-- Profile Completion Card -->
      <div class="card p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4">Profile Completion</h2>
        <div class="mb-2 flex justify-between items-center">
          <span class="text-sm font-medium text-slate-700">Score: <%= completion.score %> / <%= completion.total %></span>
          <span class="text-sm font-bold text-primary"><%= completion.percent %>%</span>
        </div>
        <div class="w-full bg-slate-200 rounded-full h-2.5">
          <div class="bg-primary h-2.5 rounded-full" style="width: <%= completion.percent %>%"></div>
        </div>
      </div>

      <!-- Profile Image Card -->
      <div class="card p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4">Profile Image</h2>
        <div class="flex flex-col items-center mb-4">
          <% if (profile.profile_image_data) { %>
            <img src="<%= profile.profile_image_data %>" alt="Profile Image" class="w-32 h-32 rounded-full object-cover border-4 border-slate-100 shadow-sm mb-4">
          <% } else { %>
            <div class="w-32 h-32 rounded-full bg-slate-100 border-4 border-slate-50 flex items-center justify-center mb-4 text-slate-400">
              <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
            </div>
          <% } %>
        </div>

        <form id="imageUploadForm" action="/profile/image" method="POST" class="space-y-3">
          <input type="hidden" name="profile_image_data" id="profile_image_data">
          <div>
            <input type="file" id="profile_image_file" accept="image/*" class="block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-primary file:text-white hover:file:bg-primary-hover">
          </div>
          <button type="submit" class="btn-primary w-full mt-2">Upload Image</button>
        </form>
      </div>
    </div>

    <!-- Right Column: Basic Profile & Addable Entities -->
    <div class="lg:col-span-2 space-y-6">
      
      <!-- Basic Profile Card -->
      <div class="card p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4 border-b border-slate-100 pb-2">Basic Information</h2>
        <form action="/profile/basic" method="POST" class="space-y-4">
          <div>
            <label for="biography" class="block text-sm font-medium text-slate-700 mb-1">Biography</label>
            <textarea id="biography" name="biography" rows="4" class="input-field"><%= profile.biography || '' %></textarea>
          </div>
          <div>
            <label for="linkedin_url" class="block text-sm font-medium text-slate-700 mb-1">LinkedIn URL</label>
            <input id="linkedin_url" type="text" name="linkedin_url" value="<%= profile.linkedin_url || '' %>" class="input-field" placeholder="https://linkedin.com/in/username">
          </div>
          <button type="submit" class="btn-primary">Save Basic Profile</button>
        </form>
      </div>

      <!-- Degrees Card -->
      <div class="card p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4 border-b border-slate-100 pb-2">Degrees</h2>
        
        <form action="/profile/degrees" method="POST" class="bg-slate-50 p-4 rounded-md mb-6 border border-slate-200">
          <h3 class="text-sm font-semibold text-slate-700 mb-3">Add New Degree</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div>
              <input type="text" name="degree_name" placeholder="Degree Name" required class="input-field">
            </div>
            <div>
              <input type="text" name="institution_name" placeholder="Institution Name" required class="input-field">
            </div>
            <div>
              <input type="text" name="degree_url" placeholder="Degree URL (Optional)" class="input-field">
            </div>
            <div>
              <input type="date" name="completion_date" class="input-field">
            </div>
          </div>
          <button type="submit" class="btn-primary text-sm">Add Degree</button>
        </form>

        <div class="space-y-4">
          <% if (degrees.length === 0) { %>
            <p class="text-sm text-slate-500 italic">No degrees added yet.</p>
          <% } %>

          <% degrees.forEach(function(item) { %>
            <div class="border border-slate-200 rounded-md p-4">
              <form action="/profile/degrees/<%= item.id %>/update" method="POST">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3">
                  <input type="text" name="degree_name" value="<%= item.degree_name %>" required class="input-field text-sm">
                  <input type="text" name="institution_name" value="<%= item.institution_name %>" required class="input-field text-sm">
                  <input type="text" name="degree_url" value="<%= item.degree_url || '' %>" placeholder="URL" class="input-field text-sm">
                  <input type="date" name="completion_date" value="<%= item.completion_date ? item.completion_date.toISOString().split('T')[0] : '' %>" class="input-field text-sm">
                </div>
                <div class="flex space-x-2">
                  <button type="submit" class="btn-secondary text-xs py-1.5">Update</button>
              </form>
              <form action="/profile/degrees/<%= item.id %>/delete" method="POST" class="inline">
                  <button type="submit" class="btn-danger text-xs py-1.5">Delete</button>
              </form>
                </div>
            </div>
          <% }); %>
        </div>
      </div>

      <!-- Certifications Card -->
      <div class="card p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4 border-b border-slate-100 pb-2">Certifications</h2>
        
        <form action="/profile/certifications" method="POST" class="bg-slate-50 p-4 rounded-md mb-6 border border-slate-200">
          <h3 class="text-sm font-semibold text-slate-700 mb-3">Add New Certification</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <input type="text" name="certification_name" placeholder="Certification Name" required class="input-field">
            <input type="text" name="provider_name" placeholder="Provider Name" required class="input-field">
            <input type="text" name="certification_url" placeholder="Certification URL (Optional)" class="input-field">
            <input type="date" name="completion_date" class="input-field">
          </div>
          <button type="submit" class="btn-primary text-sm">Add Certification</button>
        </form>

        <div class="space-y-4">
          <% if (certifications.length === 0) { %>
            <p class="text-sm text-slate-500 italic">No certifications added yet.</p>
          <% } %>

          <% certifications.forEach(function(item) { %>
            <div class="border border-slate-200 rounded-md p-4">
              <form action="/profile/certifications/<%= item.id %>/update" method="POST">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3">
                  <input type="text" name="certification_name" value="<%= item.certification_name %>" required class="input-field text-sm">
                  <input type="text" name="provider_name" value="<%= item.provider_name %>" required class="input-field text-sm">
                  <input type="text" name="certification_url" value="<%= item.certification_url || '' %>" class="input-field text-sm">
                  <input type="date" name="completion_date" value="<%= item.completion_date ? item.completion_date.toISOString().split('T')[0] : '' %>" class="input-field text-sm">
                </div>
                <div class="flex space-x-2">
                  <button type="submit" class="btn-secondary text-xs py-1.5">Update</button>
              </form>
              <form action="/profile/certifications/<%= item.id %>/delete" method="POST" class="inline">
                  <button type="submit" class="btn-danger text-xs py-1.5">Delete</button>
              </form>
                </div>
            </div>
          <% }); %>
        </div>
      </div>

      <!-- Licences Card -->
      <div class="card p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4 border-b border-slate-100 pb-2">Licences</h2>
        
        <form action="/profile/licences" method="POST" class="bg-slate-50 p-4 rounded-md mb-6 border border-slate-200">
          <h3 class="text-sm font-semibold text-slate-700 mb-3">Add New Licence</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <input type="text" name="licence_name" placeholder="Licence Name" required class="input-field">
            <input type="text" name="awarding_body" placeholder="Awarding Body" required class="input-field">
            <input type="text" name="licence_url" placeholder="Licence URL (Optional)" class="input-field">
            <input type="date" name="completion_date" class="input-field">
          </div>
          <button type="submit" class="btn-primary text-sm">Add Licence</button>
        </form>

        <div class="space-y-4">
          <% if (licences.length === 0) { %>
            <p class="text-sm text-slate-500 italic">No licences added yet.</p>
          <% } %>

          <% licences.forEach(function(item) { %>
            <div class="border border-slate-200 rounded-md p-4">
              <form action="/profile/licences/<%= item.id %>/update" method="POST">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3">
                  <input type="text" name="licence_name" value="<%= item.licence_name %>" required class="input-field text-sm">
                  <input type="text" name="awarding_body" value="<%= item.awarding_body %>" required class="input-field text-sm">
                  <input type="text" name="licence_url" value="<%= item.licence_url || '' %>" class="input-field text-sm">
                  <input type="date" name="completion_date" value="<%= item.completion_date ? item.completion_date.toISOString().split('T')[0] : '' %>" class="input-field text-sm">
                </div>
                <div class="flex space-x-2">
                  <button type="submit" class="btn-secondary text-xs py-1.5">Update</button>
              </form>
              <form action="/profile/licences/<%= item.id %>/delete" method="POST" class="inline">
                  <button type="submit" class="btn-danger text-xs py-1.5">Delete</button>
              </form>
                </div>
            </div>
          <% }); %>
        </div>
      </div>

      <!-- Short Courses Card -->
      <div class="card p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4 border-b border-slate-100 pb-2">Short Courses</h2>
        
        <form action="/profile/courses" method="POST" class="bg-slate-50 p-4 rounded-md mb-6 border border-slate-200">
          <h3 class="text-sm font-semibold text-slate-700 mb-3">Add New Short Course</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <input type="text" name="course_name" placeholder="Course Name" required class="input-field">
            <input type="text" name="provider_name" placeholder="Provider Name" required class="input-field">
            <input type="text" name="course_url" placeholder="Course URL (Optional)" class="input-field">
            <input type="date" name="completion_date" class="input-field">
          </div>
          <button type="submit" class="btn-primary text-sm">Add Short Course</button>
        </form>

        <div class="space-y-4">
          <% if (shortCourses.length === 0) { %>
            <p class="text-sm text-slate-500 italic">No short courses added yet.</p>
          <% } %>

          <% shortCourses.forEach(function(item) { %>
            <div class="border border-slate-200 rounded-md p-4">
              <form action="/profile/courses/<%= item.id %>/update" method="POST">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3">
                  <input type="text" name="course_name" value="<%= item.course_name %>" required class="input-field text-sm">
                  <input type="text" name="provider_name" value="<%= item.provider_name %>" required class="input-field text-sm">
                  <input type="text" name="course_url" value="<%= item.course_url || '' %>" class="input-field text-sm">
                  <input type="date" name="completion_date" value="<%= item.completion_date ? item.completion_date.toISOString().split('T')[0] : '' %>" class="input-field text-sm">
                </div>
                <div class="flex space-x-2">
                  <button type="submit" class="btn-secondary text-xs py-1.5">Update</button>
              </form>
              <form action="/profile/courses/<%= item.id %>/delete" method="POST" class="inline">
                  <button type="submit" class="btn-danger text-xs py-1.5">Delete</button>
              </form>
                </div>
            </div>
          <% }); %>
        </div>
      </div>

      <!-- Employment History Card -->
      <div class="card p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4 border-b border-slate-100 pb-2">Employment History</h2>
        
        <form action="/profile/employment" method="POST" class="bg-slate-50 p-4 rounded-md mb-6 border border-slate-200">
          <h3 class="text-sm font-semibold text-slate-700 mb-3">Add Employment</h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <input type="text" name="job_title" placeholder="Job Title" required class="input-field">
            <input type="text" name="company_name" placeholder="Company Name" required class="input-field">
            <div>
              <label class="block text-xs font-medium text-slate-700 mb-1">Start Date</label>
              <input type="date" name="start_date" class="input-field">
            </div>
            <div>
              <label class="block text-xs font-medium text-slate-700 mb-1">End Date</label>
              <input type="date" name="end_date" class="input-field">
            </div>
          </div>
          <button type="submit" class="btn-primary text-sm">Add Employment</button>
        </form>

        <div class="space-y-4">
          <% if (employmentHistory.length === 0) { %>
            <p class="text-sm text-slate-500 italic">No employment history added yet.</p>
          <% } %>

          <% employmentHistory.forEach(function(item) { %>
            <div class="border border-slate-200 rounded-md p-4">
              <form action="/profile/employment/<%= item.id %>/update" method="POST">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3">
                  <input type="text" name="job_title" value="<%= item.job_title %>" required class="input-field text-sm">
                  <input type="text" name="company_name" value="<%= item.company_name %>" required class="input-field text-sm">
                  <div>
                    <label class="block text-xs text-slate-500 mb-1">Start Date</label>
                    <input type="date" name="start_date" value="<%= item.start_date ? item.start_date.toISOString().split('T')[0] : '' %>" class="input-field text-sm">
                  </div>
                  <div>
                    <label class="block text-xs text-slate-500 mb-1">End Date</label>
                    <input type="date" name="end_date" value="<%= item.end_date ? item.end_date.toISOString().split('T')[0] : '' %>" class="input-field text-sm">
                  </div>
                </div>
                <div class="flex space-x-2">
                  <button type="submit" class="btn-secondary text-xs py-1.5">Update</button>
              </form>
              <form action="/profile/employment/<%= item.id %>/delete" method="POST" class="inline">
                  <button type="submit" class="btn-danger text-xs py-1.5">Delete</button>
              </form>
                </div>
            </div>
          <% }); %>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  const imageForm = document.getElementById('imageUploadForm');
  const imageFileInput = document.getElementById('profile_image_file');
  const imageDataInput = document.getElementById('profile_image_data');

  imageForm.addEventListener('submit', function (event) {
    event.preventDefault();

    const file = imageFileInput.files[0];

    if (!file) {
      alert('Please choose an image first.');
      return;
    }

    const reader = new FileReader();

    reader.onload = function () {
      imageDataInput.value = reader.result;
      imageForm.submit();
    };

    reader.readAsDataURL(file);
  });
</script>

<%- include('../partials/csrf-script') %>
<%- include('../partials/footer') %>