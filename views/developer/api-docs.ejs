<%- include('../partials/head', { title: 'API Documentation' }) %>
<!-- Swagger UI CSS -->
<link rel="stylesheet" href="https://unpkg.com/swagger-ui-dist@5/swagger-ui.css" />

<%- include('../partials/nav') %>

<div class="py-6 w-full max-w-none px-4">
  <div class="max-w-7xl mx-auto mb-6">
    <h1 class="page-title mb-1">API Documentation</h1>
    <p class="text-slate-600">Interactive Swagger/OpenAPI documentation for the Alumni Influencers API.</p>
  </div>

  <div class="bg-white shadow-sm border border-slate-200 rounded-lg overflow-hidden">
    <div id="swagger-ui"></div>
  </div>
</div>

<script src="https://unpkg.com/swagger-ui-dist@5/swagger-ui-bundle.js"></script>
<script>
  window.onload = function () {
    SwaggerUIBundle({
      url: "/docs/openapi.json",
      dom_id: "#swagger-ui",
    });
  };
</script>

<%- include('../partials/footer') %>
