<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' - Alumni Influencers' : 'Alumni Influencers' %></title>
  
  <!-- Tailwind CSS v4 CDN -->
  <script src="https://unpkg.com/@tailwindcss/browser@4"></script>
  
  <!-- Custom theme settings for a professional look -->
  <style type="text/tailwindcss">
    @theme {
      --color-primary: #1e3a8a; /* blue-900 */
      --color-primary-hover: #1e40af; /* blue-800 */
      --color-secondary: #f8fafc; /* slate-50 */
    }
    
    body {
      @apply bg-slate-50 text-slate-900 font-sans min-h-screen flex flex-col;
    }
    
    .btn-primary {
      @apply inline-flex justify-center items-center px-4 py-2 bg-primary text-white text-sm font-medium rounded-md hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-colors disabled:opacity-50 disabled:cursor-not-allowed;
    }

    .btn-secondary {
      @apply inline-flex justify-center items-center px-4 py-2 border border-slate-300 bg-white text-slate-700 text-sm font-medium rounded-md hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-colors disabled:opacity-50 disabled:cursor-not-allowed;
    }

    .btn-danger {
      @apply inline-flex justify-center items-center px-4 py-2 bg-red-600 text-white text-sm font-medium rounded-md hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-600 transition-colors;
    }

    .input-field {
      @apply w-full border border-slate-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm transition-colors;
    }

    .card {
      @apply bg-white shadow rounded-lg border border-slate-200 overflow-hidden;
    }

    .table-container {
      @apply overflow-x-auto;
    }

    .table-custom {
      @apply min-w-full divide-y divide-slate-200;
    }
    
    .table-custom th {
      @apply px-6 py-3 bg-slate-50 text-left text-xs font-medium text-slate-500 uppercase tracking-wider;
    }
    
    .table-custom td {
      @apply px-6 py-4 whitespace-nowrap text-sm text-slate-700 border-b border-slate-200;
    }

    .page-title {
      @apply text-2xl font-bold text-slate-900 mb-6;
    }
  </style>
</head>
<body>
  <div class="flex-grow flex flex-col">
