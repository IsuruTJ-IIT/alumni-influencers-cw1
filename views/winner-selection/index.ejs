<%- include('../partials/head', { title: 'Winner Selection' }) %>
<%- include('../partials/nav') %>

<div class="py-6">
  <div class="mb-8">
    <h1 class="page-title mb-1">Winner Selection Dashboard</h1>
    <p class="text-slate-600">Developer tools to monitor and manually trigger the winner selection algorithm.</p>
  </div>

  <% if (success) { %>
    <div class="bg-green-50 border-l-4 border-green-500 p-4 mb-6" role="alert">
      <p class="text-sm text-green-700"><%= success %></p>
    </div>
  <% } %>

  <% if (error) { %>
    <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6" role="alert">
      <p class="text-sm text-red-700"><%= error %></p>
    </div>
  <% } %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    
    <!-- Left Column: Status & Current Logic -->
    <div class="space-y-6">
      
      <!-- Current Time Logic -->
      <div class="card p-6 border-t-4 border-t-slate-500">
        <h2 class="text-lg font-bold text-slate-900 mb-4 border-b border-slate-100 pb-2">Current Time Logic</h2>
        <div class="space-y-3 text-sm">
          <div class="flex justify-between">
            <span class="text-slate-500">Today Slot:</span>
            <span class="font-medium text-slate-900"><%= todaySlot %></span>
          </div>
          <div class="flex justify-between">
            <span class="text-slate-500">Tomorrow Slot:</span>
            <span class="font-medium text-slate-900"><%= tomorrowSlot %></span>
          </div>
          <div class="flex justify-between items-center pt-2 border-t border-slate-100">
            <span class="text-slate-500">After 11:45 PM Right Now:</span>
            <% if (afterSixPmNow) { %>
              <span class="px-2 py-0.5 bg-green-100 text-green-800 text-xs font-bold rounded">YES</span>
            <% } else { %>
              <span class="px-2 py-0.5 bg-slate-100 text-slate-800 text-xs font-bold rounded">NO</span>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Job Run Status -->
      <div class="card p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4 border-b border-slate-100 pb-2">Job Run Status</h2>
        <div class="space-y-3 text-sm">
          <div class="flex justify-between items-center">
            <span class="text-slate-500">Select Winner Ran Today:</span>
            <% if (todaySelectionRan) { %>
              <span class="px-2 py-0.5 bg-blue-100 text-blue-800 text-xs font-bold rounded">YES</span>
            <% } else { %>
              <span class="px-2 py-0.5 bg-slate-100 text-slate-800 text-xs font-bold rounded">NO</span>
            <% } %>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-slate-500">Activate Featured Ran Today:</span>
            <% if (todayActivationRan) { %>
              <span class="px-2 py-0.5 bg-blue-100 text-blue-800 text-xs font-bold rounded">YES</span>
            <% } else { %>
              <span class="px-2 py-0.5 bg-slate-100 text-slate-800 text-xs font-bold rounded">NO</span>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Grant Event Bonus -->
      <div class="card p-6 border-l-4 border-l-indigo-500 bg-indigo-50">
        <h2 class="text-lg font-bold text-indigo-900 mb-2 border-b border-indigo-200 pb-2">Grant Event Bonus</h2>
        <p class="text-xs text-indigo-700 mb-4">
          Local testing only. Simulates alumnus attending an event to grant a 4th monthly appearance.
        </p>

        <form action="/winner-selection/event-bonus" method="POST" class="space-y-3">
          <div>
            <label class="block text-xs font-medium text-indigo-800 mb-1">Alumnus User ID</label>
            <input type="number" name="alumnus_user_id" min="1" required class="input-field text-sm border-indigo-200 focus:border-indigo-500 focus:ring-indigo-500 bg-white">
          </div>
          <div>
            <label class="block text-xs font-medium text-indigo-800 mb-1">Event Month</label>
            <input type="month" name="event_month" required class="input-field text-sm border-indigo-200 focus:border-indigo-500 focus:ring-indigo-500 bg-white">
          </div>
          <button type="submit" class="btn-primary w-full bg-indigo-600 hover:bg-indigo-700 text-sm">Grant Event Bonus</button>
        </form>
      </div>

    </div>

    <!-- Right Column: Slots & Manual Controls -->
    <div class="lg:col-span-2 space-y-6">
      
      <!-- Leading Bid -->
      <div class="card p-6 shadow-sm border-t-4 border-t-amber-400">
        <h2 class="text-lg font-bold text-slate-900 mb-4 border-b border-slate-100 pb-2">Current Leading Eligible Bid (Tomorrow)</h2>
        <% if (leadingBid) { %>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 bg-amber-50 p-4 rounded-lg border border-amber-100">
            <div>
              <span class="block text-xs text-amber-700 font-medium">Bid ID</span>
              <span class="text-sm font-bold text-amber-900"><%= leadingBid.id %></span>
            </div>
            <div>
              <span class="block text-xs text-amber-700 font-medium">User ID</span>
              <span class="text-sm font-bold text-amber-900"><%= leadingBid.user_id %></span>
            </div>
            <div>
              <span class="block text-xs text-amber-700 font-medium">Bid Amount</span>
              <span class="text-sm font-bold text-amber-900">$<%= leadingBid.bid_amount %></span>
            </div>
            <div>
              <span class="block text-xs text-amber-700 font-medium">Status</span>
              <span class="text-sm font-bold text-amber-900"><%= leadingBid.status %></span>
            </div>
          </div>
        <% } else { %>
          <div class="p-4 text-sm text-slate-500 italic bg-slate-50 rounded-lg">No eligible leading bid for tomorrow yet.</div>
        <% } %>
      </div>

      <!-- Slots Info -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Today Featured Slot -->
        <div class="card p-6 shadow-sm">
          <h2 class="text-sm font-bold uppercase tracking-wider text-slate-500 mb-4 border-b border-slate-100 pb-2">Today's Featured Slot</h2>
          <% if (todayFeatured) { %>
            <div class="space-y-3 text-sm">
              <div>
                <span class="block text-xs text-slate-500">Featured User ID</span>
                <span class="font-medium text-slate-900"><%= todayFeatured.featured_user_id || '-' %></span>
              </div>
              <div>
                <span class="block text-xs text-slate-500">Full Name</span>
                <span class="font-bold text-primary"><%= todayFeatured.full_name || '-' %></span>
              </div>
              <div>
                <span class="block text-xs text-slate-500">Selected At</span>
                <span class="text-slate-700"><%= todayFeatured.selected_at || '-' %></span>
              </div>
              <div>
                <span class="block text-xs text-slate-500">Activated At</span>
                <span class="text-slate-700"><%= todayFeatured.activated_at || '-' %></span>
              </div>
            </div>
          <% } else { %>
            <p class="text-sm text-slate-500 italic bg-slate-50 p-3 rounded">No featured slot row exists for today yet.</p>
          <% } %>
        </div>

        <!-- Tomorrow Featured Slot -->
        <div class="card p-6 shadow-sm">
          <h2 class="text-sm font-bold uppercase tracking-wider text-slate-500 mb-4 border-b border-slate-100 pb-2">Tomorrow's Featured Slot</h2>
          <% if (tomorrowFeatured) { %>
            <div class="space-y-3 text-sm">
              <div>
                <span class="block text-xs text-slate-500">Featured User ID</span>
                <span class="font-medium text-slate-900"><%= tomorrowFeatured.featured_user_id || '-' %></span>
              </div>
              <div>
                <span class="block text-xs text-slate-500">Full Name</span>
                <span class="font-bold text-indigo-600"><%= tomorrowFeatured.full_name || '-' %></span>
              </div>
              <div>
                <span class="block text-xs text-slate-500">Selected At</span>
                <span class="text-slate-700"><%= tomorrowFeatured.selected_at || '-' %></span>
              </div>
              <div>
                <span class="block text-xs text-slate-500">Activated At</span>
                <span class="text-slate-700"><%= tomorrowFeatured.activated_at || '-' %></span>
              </div>
            </div>
          <% } else { %>
            <p class="text-sm text-slate-500 italic bg-slate-50 p-3 rounded">No featured slot row exists for tomorrow yet.</p>
          <% } %>
        </div>
      </div>

      <!-- Local Demo Buttons -->
      <div class="card p-6 bg-slate-50 border-slate-200">
        <h2 class="text-lg font-bold text-slate-900 mb-2 border-b border-slate-200 pb-2">Local Demo Controls</h2>
        <p class="text-sm text-slate-600 mb-4">Use these buttons to manually test the logic without waiting for the scheduler cutoffs.</p>

        <div class="flex flex-col sm:flex-row gap-3">
          <form action="/winner-selection/demo-select" method="POST" class="flex-1">
            <button type="submit" class="btn-secondary w-full py-2">Select Tomorrow Winner Now</button>
          </form>
          
          <form action="/winner-selection/demo-activate" method="POST" class="flex-1">
            <button type="submit" class="btn-secondary w-full py-2">Activate Today Featured Now</button>
          </form>
          
          <form action="/winner-selection/run-cycle" method="POST" class="flex-1">
            <button type="submit" class="btn-primary w-full py-2 bg-slate-800 hover:bg-slate-900 border-slate-800">Run Full Cycle Now</button>
          </form>
        </div>
      </div>

    </div>
  </div>
</div>

<%- include('../partials/csrf-script') %>
<%- include('../partials/footer') %>