<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Alumni Influencers</title>
</head>
<body>
  <h1>Alumni Influencers</h1>

  <% if (!currentUser) { %>
    <p><a href="/register">Register</a></p>
    <p><a href="/login">Login</a></p>
    <p><a href="/forgot-password">Forgot Password</a></p>
  <% } %>

  <% if (currentUser) { %>
    <hr>
    <p>You are logged in as: <strong><%= currentUser.email %></strong></p>
    <p>Role: <strong><%= currentUser.role %></strong></p>

    <p><a href="/dashboard">Dashboard</a></p>

    <% if (currentUser.role === 'alumnus') { %>
      <p><a href="/profile">My Profile</a></p>
      <p><a href="/bidding">Bidding Dashboard</a></p>
    <% } %>

    <% if (currentUser.role === 'university') { %>
      <p><a href="/university/dashboard">University Analytics Dashboard</a></p>
      <p><a href="/university/alumni">View Alumni Analytics</a></p>
    <% } %>

    <% if (currentUser.role === 'developer') { %>
      <p><a href="/developer/tokens">Developer Tokens</a></p>
      <p><a href="/winner-selection">Winner Selection Dashboard</a></p>
      <p><a href="/api-docs">Swagger / OpenAPI Docs</a></p>
      <p><a href="/outbox">Open Local Outbox</a></p>
    <% } %>

    <form action="/logout" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit">Logout</button>
    </form>
  <% } %>
</body>
</html>