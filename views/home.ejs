<%- include('partials/head', { title: 'Home' }) %>
<%- include('partials/nav') %>

<div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
  <h1 class="text-4xl sm:text-5xl font-extrabold text-primary mb-6 tracking-tight">Welcome to Alumni Influencers</h1>
  <p class="text-lg sm:text-xl text-slate-600 mb-10 max-w-2xl">Connect, bid on valuable networking opportunities, and empower your university community with data-driven insights.</p>

  <% if (!currentUser) { %>
    <div class="flex flex-col sm:flex-row gap-4">
      <a href="/register" class="btn-primary px-8 py-3 text-lg">Get Started</a>
      <a href="/login" class="btn-secondary px-8 py-3 text-lg">Sign In</a>
    </div>
  <% } else { %>
    <div class="card p-8 w-full max-w-lg text-left">
      <h2 class="text-2xl font-bold text-slate-900 mb-4">Welcome back!</h2>
      <div class="space-y-3 mb-6">
        <p class="text-slate-600"><span class="font-medium text-slate-900">Email:</span> <%= currentUser.email %></p>
        <p class="text-slate-600"><span class="font-medium text-slate-900">Role:</span> <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 capitalize"><%= currentUser.role %></span></p>
      </div>
      
      <div class="flex justify-center">
        <a href="/dashboard" class="btn-primary w-full">Go to Dashboard &rarr;</a>
      </div>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>